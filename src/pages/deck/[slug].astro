---
import Layout from '../../layouts/Layout.astro';
import { decks } from '../../data/decks';

export function getStaticPaths() {
  return Object.keys(decks).map((slug) => ({
    params: { slug },
    props: { deck: decks[slug] },
  }));
}

const { deck } = Astro.props;
const { slug, title, accentColor, accentBg, accentText, slides } = deck;
---

<Layout title={`${title} — Presentation`}>
  <div class="deck-page" style={`--dk-accent-raw:${accentColor};--dk-accent-bg:${accentBg};--dk-accent-text:${accentText};`}>
    <!-- Top bar: back link + counter -->
    <div class="dk-top-bar">
      <a href="/projects" class="dk-back" id="dk-back-btn" data-fluid-dk>
        <span class="dk-back__highlight"></span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back
      </a>
      <span class="dk-slide-counter" id="counter">1 / {slides.length}</span>
    </div>

    <!-- Floating bottom nav -->
    <div class="dk-float-nav">
      <button class="dk-nav-arrow" id="prev-btn" disabled data-fluid-dk>
        <span class="dk-nav-arrow__highlight"></span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="dk-nav-selector">
        <button class="dk-nav-current" id="nav-current" data-fluid-dk>
          <span class="dk-nav-current__highlight"></span>
          <span id="current-label">{slides[0].label}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="dk-nav-dropdown dk-dropdown-fluid" id="nav-dropdown">
          {slides.map((s, i) => (
            <button
              class={`dk-dropdown-item ${i === 0 ? 'active' : ''}`}
              data-pill-index={i}
            >
              <span class="dk-dropdown-highlight"></span>
              <span class="dk-dropdown-num">{String(i + 1).padStart(2, '0')}</span>
              {s.label}
            </button>
          ))}
        </div>
      </div>
      <button class="dk-nav-arrow" id="next-btn" data-fluid-dk>
        <span class="dk-nav-arrow__highlight"></span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    {slides.map((s, i) => (
      <div class={`dk-slide ${i === 0 ? 'active' : ''}`} data-slide-index={i}>
        <div class="dk-slide-body" set:html={s.content} />
      </div>
    ))}
  </div>
</Layout>

<style is:global>
  /* ─── Hide site nav & footer on deck pages ─── */
  .deck-page ~ footer,
  body > nav,
  body > header { display: none; }

  /* ─── Deck Layout ─── */
  .deck-page {
    --dk-accent: var(--dk-accent-raw);
    max-width: 720px;
    margin: 0 auto;
    min-height: 100vh;
    padding-bottom: 100px;
  }

  /* Darken deck accent for light-mode contrast */
  [data-theme='light'] .deck-page {
    --dk-accent: color-mix(in srgb, var(--dk-accent-raw), black 40%);
  }

  /* ─── Top Bar ─── */
  .dk-top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    border-bottom: 0.5px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 100;
  }

  /* Back link */
  .dk-back {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    margin-left: -12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--font-body);
    white-space: nowrap;
    transition: color 0.15s;
    flex-shrink: 0;
    cursor: none;
    border-radius: 8px;
  }

  .dk-back__highlight {
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: var(--overlay-soft);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    clip-path: circle(0% at 50% 50%);
  }

  .dk-back svg {
    position: relative;
    z-index: 1;
  }

  .dk-back:hover { color: var(--text); }

  /* ─── Floating Bottom Nav ─── */
  .dk-float-nav {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--overlay-border-mid);
    border-radius: var(--radius-full);
    background: var(--nav-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 5px 6px;
    z-index: 100;
    box-shadow: 0 8px 32px var(--shadow-color), 0 0 0 1px var(--overlay-muted), 0 0 48px var(--shadow-light);
  }

  .dk-nav-arrow {
    position: relative;
    overflow: hidden;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--overlay-soft);
    color: var(--text);
    cursor: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.25s ease;
    flex-shrink: 0;
  }

  .dk-nav-arrow svg {
    position: relative;
    z-index: 1;
  }

  .dk-nav-arrow__highlight {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    clip-path: circle(0% at 50% 50%);
  }

  .dk-nav-arrow:hover {
    color: var(--btn-hover-text);
  }

  .dk-nav-arrow:disabled {
    opacity: 0.2;
    cursor: default;
    background: transparent;
  }

  /* Dropdown selector */
  .dk-nav-selector {
    position: relative;
    width: 160px;
    flex-shrink: 0;
  }

  .dk-nav-current {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 14px;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: none;
    white-space: nowrap;
    transition: color 0.25s ease;
    width: 100%;
    text-overflow: ellipsis;
    letter-spacing: 0.2px;
    border-radius: var(--radius-full);
  }

  .dk-nav-current__highlight {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    background: var(--overlay-soft);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    clip-path: circle(0% at 50% 50%);
  }

  .dk-nav-current #current-label,
  .dk-nav-current svg {
    position: relative;
    z-index: 1;
  }

  .dk-nav-current:hover { color: var(--text); }

  .dk-nav-current svg {
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .dk-nav-selector.open .dk-nav-current svg {
    transform: rotate(180deg);
  }

  /* Counter in top bar */
  .dk-top-bar .dk-slide-counter {
    font-size: 11px;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  /* Dropdown menu — opens upward from floating nav */
  .dk-nav-dropdown {
    display: none;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: var(--bg-elevated);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 4px;
    box-shadow: 0 -8px 32px var(--shadow-color);
    z-index: 200;
  }

  .dk-nav-selector.open .dk-nav-dropdown {
    display: block;
  }

  .dk-dropdown-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 12px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 13px;
    font-family: var(--font-body);
    cursor: none;
    border-radius: var(--radius-sm);
    text-align: left;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .dk-dropdown-highlight {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-sm);
    background: var(--overlay-soft);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    clip-path: circle(0% at 50% 50%);
  }

  .dk-dropdown-item .dk-dropdown-num {
    position: relative;
    z-index: 1;
  }

  .dk-dropdown-item:hover {
    color: var(--text);
  }

  .dk-dropdown-item.active {
    color: var(--dk-accent);
    background: var(--overlay-muted);
  }

  .dk-dropdown-num {
    font-size: 10px;
    font-weight: 600;
    color: var(--overlay-num);
    min-width: 16px;
  }

  .dk-dropdown-item.active .dk-dropdown-num {
    color: var(--dk-accent);
    opacity: 0.6;
  }

  .dk-slide-counter {
    font-size: 11px;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Slide ─── */
  .dk-slide {
    display: none;
    padding: 0;
  }

  .dk-slide.active {
    display: block;
  }

  .dk-slide-body {
    padding: 40px 48px 56px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ─── Slide Content Elements ─── */
  .tag {
    display: inline-block;
    font-size: 13px;
    padding: 5px 14px;
    border-radius: var(--radius-full);
    font-weight: 500;
    margin-bottom: 16px;
    background: var(--overlay-soft);
    color: var(--dk-accent);
    border: 0.5px solid var(--overlay-border-subtle);
  }

  .slide-label {
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .slide-title {
    font-size: 32px;
    font-weight: 500;
    font-family: var(--font-display);
    color: var(--text);
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .slide-subtitle {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  .divider {
    height: 0.5px;
    background: var(--border);
    margin: 28px 0;
  }

  /* ─── Metrics ─── */
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 24px 0;
  }

  .metric-grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .metric-card {
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
    padding: 20px;
    border: 0.5px solid var(--border);
  }

  .metric-num {
    font-size: 34px;
    font-weight: 600;
    font-family: var(--font-display);
    color: var(--dk-accent);
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-label {
    font-size: 14px;
    color: var(--text-muted);
  }

  /* ─── Info Grid ─── */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    font-size: 15px;
  }

  .info-label {
    color: var(--text-muted);
    margin-bottom: 3px;
    font-size: 13px;
  }

  .info-value {
    color: var(--text);
    font-weight: 500;
    font-size: 15px;
  }

  /* ─── Quote Block ─── */
  .quote-block {
    border-left: 3px solid var(--dk-accent);
    padding: 16px 24px;
    background: var(--bg-elevated);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: 24px 0;
  }

  .quote-text {
    font-size: 17px;
    color: var(--text);
    line-height: 1.65;
    font-style: italic;
  }

  .quote-attr {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* ─── Steps ─── */
  .step-row {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin: 16px 0;
  }

  .step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--overlay-soft);
    color: var(--dk-accent);
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
    border: 0.5px solid var(--overlay-border-subtle);
  }

  .step-content { flex: 1; }

  .step-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
  }

  .step-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-top: 4px;
  }

  /* ─── Knowledge/Feature Card ─── */
  .kf-card {
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    margin: 16px 0;
    background: var(--card-bg);
  }

  .kf-head {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 6px;
  }

  .kf-body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ─── Insight Row ─── */
  .insight-row {
    display: flex;
    gap: 10px;
    margin: 10px 0;
    align-items: flex-start;
  }

  .insight-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    background: var(--overlay-soft);
    border: 0.5px solid var(--border);
  }

  .insight-body { flex: 1; }

  /* ─── Before / After Row ─── */
  .ba-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 20px 0;
  }

  .ba-box {
    border-radius: var(--radius-md);
    padding: 18px;
    font-size: 15px;
    line-height: 1.6;
  }

  .ba-before {
    background: var(--bg-elevated);
    border: 0.5px solid var(--border);
    color: var(--text-muted);
  }

  .ba-after {
    background: var(--overlay-muted);
    border: 0.5px solid var(--overlay-hover);
    color: var(--text);
  }

  .ba-label {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ba-before .ba-label { color: var(--text-muted); }
  .ba-after .ba-label { color: var(--dk-accent); }

  /* ─── Reflection Card ─── */
  .reflection-card {
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border);
    padding: 20px 24px;
    margin: 14px 0;
    background: var(--card-bg);
  }

  .refl-num {
    font-size: 13px;
    font-weight: 600;
    color: var(--dk-accent);
    margin-bottom: 6px;
  }

  .refl-title {
    font-size: 17px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 6px;
  }

  .refl-body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ─── Impact Table ─── */
  .impact-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin-top: 16px;
  }

  .impact-table th {
    text-align: left;
    padding: 10px;
    color: var(--text-muted);
    font-weight: 500;
    border-bottom: 0.5px solid var(--border);
  }

  .impact-table td {
    padding: 10px;
    border-bottom: 0.5px solid var(--border);
    color: var(--text);
  }

  .impact-table .good {
    color: var(--dk-accent);
    font-weight: 600;
  }

  /* ─── Screen (image/video container) ─── */
  .screen {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 0.5px solid var(--border);
    margin: 16px 0;
    background: var(--bg-elevated);
  }

  .screen img,
  .screen video {
    width: 100%;
    display: block;
    height: 380px;
    object-fit: contain;
    background: var(--bg-elevated);
  }

  .screen-caption {
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
    padding: 10px 14px;
    background: var(--bg-elevated);
    border-top: 0.5px solid var(--border);
  }

  .screen-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin: 24px 0;
  }

  .screen-row .screen {
    margin: 0;
  }

  .screen-row .screen img,
  .screen-row .screen video {
    height: 320px;
  }

  .screen-row-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .screen-row-3 .screen img,
  .screen-row-3 .screen video {
    height: 400px;
  }

  /* ─── Mobile ─── */
  @media (max-width: 640px) {
    .dk-top-bar { padding: 8px 12px; }
    .dk-back { font-size: 11px; gap: 4px; }
    .dk-back svg { width: 12px; height: 12px; }
    .dk-float-nav { bottom: 16px; padding: 5px 6px; }
    .dk-nav-arrow { width: 44px; height: 44px; }
    .dk-nav-arrow svg { width: 16px; height: 16px; }
    .dk-nav-current { font-size: 14px; padding: 10px 14px; min-height: 44px; }
    .dk-dropdown-item { padding: 12px 14px; font-size: 14px; min-height: 44px; }
    .dk-top-bar .dk-slide-counter { font-size: 10px; }
    .dk-slide-body { padding: 24px 18px 40px; }
    .slide-title { font-size: 24px; }
    .slide-subtitle { font-size: 15px; }
    .metric-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-grid-3 { grid-template-columns: repeat(2, 1fr); }
    .metric-num { font-size: 26px; }
    .step-title { font-size: 15px; }
    .step-desc { font-size: 14px; }
    .kf-head { font-size: 14px; }
    .kf-body { font-size: 14px; }
    .quote-text { font-size: 15px; }
    .refl-title { font-size: 15px; }
    .refl-body { font-size: 14px; }
    .ba-row { grid-template-columns: 1fr; gap: 8px; }
    .screen img, .screen video { height: 260px; }
    .screen-row { grid-template-columns: 1fr; }
    .screen-row .screen img, .screen-row .screen video { height: 260px; }
    .screen-row-3 { grid-template-columns: repeat(2, 1fr); }
    .screen-row-3 .screen img, .screen-row-3 .screen video { height: 300px; }
    .info-grid { grid-template-columns: 1fr; gap: 8px; }
  }

  /* ─── Lightbox ─── */
  .dk-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--lightbox-bg);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease;
    cursor: zoom-out;
  }

  .dk-lightbox--visible {
    opacity: 1;
  }

  .dk-lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    pointer-events: auto;
    opacity: 1;
    transform: none;
  }

  .dk-lightbox video {
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    pointer-events: auto;
  }

  .dk-lightbox__close {
    position: fixed;
    top: 8px;
    right: 12px;
    z-index: 10000;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 20px;
    cursor: none;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: color 0.15s, background 0.15s;
  }

  .dk-lightbox__close:hover {
    color: var(--text);
    background: var(--overlay-border-subtle);
  }

  .dk-lightbox__hint {
    position: fixed;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: var(--text-muted);
    opacity: 0.6;
    pointer-events: none;
  }

  /* Make screen images look clickable */
  .screen img,
  .screen video {
    cursor: zoom-in;
  }

  /* Invert dark-themed SVG diagrams in light mode */
  [data-theme='light'] .screen img[src$=".svg"] {
    filter: invert(1) hue-rotate(180deg);
  }
</style>

<script is:inline>
  // Contextual back button
  (function() {
    var btn = document.getElementById('dk-back-btn');
    if (!btn) return;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      if (document.referrer) {
        try {
          var ref = new URL(document.referrer);
          if (ref.origin === location.origin) {
            history.back();
            return;
          }
        } catch(err) {}
      }
      location.href = '/projects';
    });
  })();

  function initDeck() {
    const allSlides = document.querySelectorAll('[data-slide-index]');
    const allPills = document.querySelectorAll('[data-pill-index]');
    const counter = document.getElementById('counter');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const currentLabel = document.getElementById('current-label');
    const navCurrent = document.getElementById('nav-current');
    const selector = navCurrent?.closest('.dk-nav-selector');
    const dropdown = document.getElementById('nav-dropdown');

    if (!allSlides.length || !counter || !prevBtn || !nextBtn) return;

    const totalSlides = allSlides.length;
    let current = 0;

    function goTo(index) {
      if (index < 0 || index >= totalSlides) return;
      current = index;

      allSlides.forEach((s, i) => s.classList.toggle('active', i === current));
      allPills.forEach((p, i) => p.classList.toggle('active', i === current));

      counter.textContent = `${current + 1} / ${totalSlides}`;
      const pill = allPills[current];
      const numSpan = pill?.querySelector('.dk-dropdown-num');
      currentLabel.textContent = numSpan ? pill.textContent.replace(numSpan.textContent, '').trim() : (pill?.textContent?.trim() || '');
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current === totalSlides - 1;

      // Close dropdown
      selector?.classList.remove('open');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Arrow buttons
    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    // Dropdown toggle
    navCurrent?.addEventListener('click', (e) => {
      e.stopPropagation();
      selector.classList.toggle('open');
    });

    // Dropdown items
    allPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        goTo(Number(pill.dataset.pillIndex));
      });
    });

    // Close dropdown on outside click
    document.addEventListener('click', () => {
      selector?.classList.remove('open');
    });

    dropdown?.addEventListener('click', (e) => e.stopPropagation());

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); goTo(current + 1); }
      if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'Escape') selector?.classList.remove('open');
    });

    // Touch/swipe
    let touchStartX = 0;
    document.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goTo(current + 1);
        else goTo(current - 1);
      }
    });

    // Always start at slide 0
    goTo(0);

    // Lightbox for images and videos
    document.querySelectorAll('.dk-slide-body .screen img, .dk-slide-body .screen video').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        document.body.style.overflow = 'hidden';

        var overlay = document.createElement('div');
        overlay.className = 'dk-lightbox';

        var closeBtn = document.createElement('button');
        closeBtn.className = 'dk-lightbox__close';
        closeBtn.innerHTML = '✕';
        closeBtn.setAttribute('aria-label', 'Close');
        overlay.appendChild(closeBtn);

        var isMobile = window.innerWidth <= 768;
        var hint = document.createElement('span');
        hint.className = 'dk-lightbox__hint';
        hint.textContent = isMobile ? 'Pinch to zoom · Tap to close' : 'Click anywhere to close';
        overlay.appendChild(hint);

        var clone;
        if (el.tagName === 'VIDEO') {
          clone = document.createElement('video');
          clone.src = el.src;
          clone.autoplay = true;
          clone.loop = true;
          clone.muted = false;
          clone.playsInline = true;
          clone.controls = true;
        } else {
          clone = document.createElement('img');
          clone.src = el.src;
          clone.alt = el.alt || '';
        }
        overlay.appendChild(clone);

        function closeLightbox() {
          document.body.style.overflow = '';
          overlay.classList.remove('dk-lightbox--visible');
          setTimeout(function() { overlay.remove(); }, 300);
        }

        closeBtn.addEventListener('click', function(ev) { ev.stopPropagation(); closeLightbox(); });
        overlay.addEventListener('click', function(ev) { if (ev.target === overlay) closeLightbox(); });

        var onKey = function(ev) {
          if (ev.key === 'Escape') { closeLightbox(); window.removeEventListener('keydown', onKey); }
        };
        window.addEventListener('keydown', onKey);

        document.body.appendChild(overlay);
        requestAnimationFrame(function() { overlay.classList.add('dk-lightbox--visible'); });
      });
    });
  }

  // Fluid highlight for deck nav buttons + dropdown items
  function initDeckFluid() {
    // Nav arrows + current label
    document.querySelectorAll('[data-fluid-dk]').forEach(function(btn) {
      var highlight = btn.querySelector('.dk-nav-arrow__highlight') || btn.querySelector('.dk-nav-current__highlight') || btn.querySelector('.dk-back__highlight');
      if (!highlight) return;

      btn.addEventListener('mouseenter', function(e) {
        if (btn.disabled) return;
        var rect = btn.getBoundingClientRect();
        var cx = e.clientX - rect.left;
        var cy = e.clientY - rect.top;
        highlight.style.clipPath = 'circle(0% at ' + cx + 'px ' + cy + 'px)';
        highlight.style.opacity = '1';
        requestAnimationFrame(function() {
          highlight.style.transition = 'clip-path 0.45s cubic-bezier(0.4, 0, 0.2, 1)';
          highlight.style.clipPath = 'circle(150% at ' + cx + 'px ' + cy + 'px)';
        });
      });

      btn.addEventListener('mouseleave', function(e) {
        var rect = btn.getBoundingClientRect();
        var cx = e.clientX - rect.left;
        var cy = e.clientY - rect.top;
        highlight.style.transition = 'clip-path 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.15s ease 0.2s';
        highlight.style.clipPath = 'circle(0% at ' + cx + 'px ' + cy + 'px)';
        setTimeout(function() { highlight.style.opacity = '0'; }, 300);
      });
    });

    // Dropdown items — same fluid highlight as header nav
    document.querySelectorAll('.dk-dropdown-fluid').forEach(function(wrap) {
      var items = wrap.querySelectorAll('.dk-dropdown-item');
      items.forEach(function(item) {
        var hl = item.querySelector('.dk-dropdown-highlight');
        if (!hl) return;

        item.addEventListener('mouseenter', function(e) {
          var rect = item.getBoundingClientRect();
          var cx = e.clientX - rect.left;
          var cy = e.clientY - rect.top;
          hl.style.clipPath = 'circle(0% at ' + cx + 'px ' + cy + 'px)';
          hl.style.opacity = '1';
          requestAnimationFrame(function() {
            hl.style.transition = 'clip-path 0.45s cubic-bezier(0.4, 0, 0.2, 1)';
            hl.style.clipPath = 'circle(150% at ' + cx + 'px ' + cy + 'px)';
          });
        });

        item.addEventListener('mouseleave', function(e) {
          var rect = item.getBoundingClientRect();
          var cx = e.clientX - rect.left;
          var cy = e.clientY - rect.top;
          hl.style.transition = 'clip-path 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.15s ease 0.2s';
          hl.style.clipPath = 'circle(0% at ' + cx + 'px ' + cy + 'px)';
          setTimeout(function() { hl.style.opacity = '0'; }, 300);
        });
      });
    });
  }

  initDeck();
  initDeckFluid();
  document.addEventListener('astro:after-swap', function() { initDeck(); initDeckFluid(); });
</script>
