---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav';
import FooterCTA from '../components/FooterCTA.astro';
import { projects } from '../data/projects';
import { decks } from '../data/decks';

const sorted = projects.filter(p => !p.hidden).sort((a, b) => a.order - b.order);
---

<Layout title="Projects — Ashish Khoshya" description="Selected projects by Ashish Khoshya — design systems, enterprise UX, and product architecture.">
  <TopNav currentPath="/projects" client:load />

  <main id="main-content" class="proj-page">
    <!-- Header -->
    <div class="content-wrap proj-page__header">
      <h1 class="proj-page__header-title">Selected Projects</h1>
      <div class="proj-page__header-meta">
        <span class="proj-page__header-count">{sorted.length} Case Studies</span>
        <span class="proj-page__header-sep">/</span>
        <span class="proj-page__header-year">2021 — 2026</span>
      </div>
    </div>

    <!-- Full-width project list -->
    <div class="content-wrap proj-page__grid">
      {sorted.map((p, i) => (
        <article class="gd-card" data-card-index={i}>
          <div class="gd-card__body">
            <div class="gd-card__eyebrow">
              <span class="gd-card__index">{String(i + 1).padStart(2, '0')}</span>
              <span class="gd-card__eyebrow-sep" aria-hidden="true">—</span>
              <span class="gd-card__category">{p.category}</span>
            </div>
            <h2 class="gd-card__title">{p.title}</h2>
            <p class="gd-card__subtitle">{p.subtitle}</p>
            <p class="gd-card__overview">{p.overview}</p>
            <div class="gd-card__footer">
              <div class="gd-card__meta">
                <span class="gd-card__meta-item">{p.role}</span>
                <span class="gd-card__meta-sep" aria-hidden="true">·</span>
                <span class="gd-card__meta-item">{p.year}</span>
              </div>
              <div class="gd-card__ctas">
                <span class="gd-cta-highlight"></span>
                <a
                  href={`/project/${p.slug}`}
                  class="gd-cta"
                >
                  {p.slug === 'memoir' && (
                    <svg class="gd-cta__lock" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  )}
                  <span>Case Study</span>
                  <svg class="gd-cta__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
                {false && decks[p.slug] && (
                  <a
                    href={`/deck/${p.slug}`}
                    class="gd-cta"
                  >
                    Quick Read
                  </a>
                )}
              </div>
            </div>
          </div>
          <a href={`/project/${p.slug}`} class="gd-card__img-link" data-cursor="View">
            <img
              src={p.coverImage}
              alt={p.title}
              class="gd-card__img"
              loading={i < 2 ? 'eager' : 'lazy'}
              data-slug={p.slug}
              data-cover={p.coverImage}
            />
          </a>
        </article>
      ))}
    </div>

    <div id="contact">
      <FooterCTA />
    </div>
  </main>
</Layout>

<style>
  .proj-page {
    padding-top: 120px;
  }

  /* Header */
  .proj-page__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 0.5px solid var(--border);
  }

  .proj-page__header-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.1;
  }

  .proj-page__header-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  .proj-page__header-sep { opacity: 0.3; }
  .proj-page__header-count { font-weight: 500; }
  .proj-page__header-year { font-variant-numeric: tabular-nums; }

  /* ── Full-width project list ── */
  .proj-page__grid {
    display: flex;
    flex-direction: column;
    gap: 72px;
    padding-bottom: 96px;
  }

  /* ── Card: text left, image right ── */
  .gd-card {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.25fr);
    gap: 56px;
    align-items: center;
    overflow: visible;
    background: transparent;
  }

  /* Text body */
  .gd-card__body {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .gd-card__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .gd-card__index {
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    font-weight: 700;
  }

  .gd-card__eyebrow-sep {
    opacity: 0.4;
  }

  .gd-card__category {
    opacity: 0.85;
  }

  .gd-card__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 2.4vw, 34px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .gd-card__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(15px, 1.2vw, 17px);
    color: color-mix(in srgb, var(--text) 75%, transparent);
    line-height: 1.45;
    margin: 0;
  }

  .gd-card__overview {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 6px 0 0;
    max-width: 52ch;
  }

  .gd-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 18px;
    padding-top: 18px;
    border-top: 0.5px solid var(--border);
    flex-wrap: wrap;
  }

  .gd-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.4px;
  }

  .gd-card__meta-sep {
    opacity: 0.35;
  }

  /* CTAs */
  .gd-card__ctas {
    position: relative;
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    width: fit-content;
  }

  .gd-cta-highlight {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    border-radius: var(--radius-full);
    background: var(--accent);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    clip-path: circle(0% at 50% 50%);
  }

  .gd-cta {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--text);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s ease, border-color 0.25s ease;
    cursor: none;
  }

  .gd-cta--active {
    color: var(--btn-hover-text);
    border-color: transparent;
  }

  .gd-cta__lock {
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity 0.25s ease;
  }

  .gd-cta--active .gd-cta__lock {
    opacity: 0.8;
  }

  .gd-cta__arrow {
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.3s var(--ease-out-expo), opacity 0.25s ease;
  }

  .gd-card:hover .gd-cta__arrow {
    transform: translateX(3px);
    opacity: 1;
  }

  .gd-cta--active .gd-cta__arrow {
    opacity: 0.9;
  }

  /* Image side */
  .gd-card__img-link {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 20px;
    border: 0.5px solid var(--border);
    aspect-ratio: 16 / 9;
    background: var(--surface, #0a0a0a);
    transition: border-radius 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo), box-shadow 0.6s var(--ease-out-expo);
    cursor: none;
    box-shadow: 0 1px 2px color-mix(in srgb, #000 12%, transparent);
  }

  .gd-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.7s var(--ease-out-expo);
  }

  .gd-card:hover .gd-card__img-link {
    border-radius: 28px;
    transform: translateY(-3px);
    box-shadow: 0 24px 48px -16px color-mix(in srgb, #000 40%, transparent), 0 4px 12px color-mix(in srgb, #000 18%, transparent);
  }

  .gd-card:hover .gd-card__img {
    transform: scale(1.04);
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .gd-card {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 36px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .proj-page {
      padding-top: 80px;
    }

    .proj-page__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 32px;
    }

    .proj-page__grid {
      gap: 56px;
    }

    .gd-card {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .gd-card__img-link {
      order: -1;
      border-radius: 16px;
      box-shadow: none;
    }

    .gd-card:hover .gd-card__img-link {
      border-radius: 18px;
      transform: none;
    }

    .gd-card__body {
      gap: 8px;
      padding: 4px 0 0;
    }

    .gd-card__eyebrow {
      font-size: 10.5px;
      letter-spacing: 1.2px;
      gap: 8px;
      margin-bottom: 2px;
    }

    .gd-card__title {
      font-size: 22px;
      line-height: 1.2;
    }

    .gd-card__subtitle {
      font-size: 14px;
      font-style: normal;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .gd-card__overview {
      display: none;
    }

    .gd-card__footer {
      margin-top: 10px;
      padding-top: 12px;
      gap: 12px;
    }

    .gd-card__meta {
      font-size: 11.5px;
    }

    .gd-cta {
      padding: 8px 16px;
      font-size: 12px;
      gap: 6px;
      background: transparent;
    }

    .gd-cta__arrow {
      width: 12px;
      height: 12px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initProjectsPage() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cards = document.querySelectorAll('.gd-card');

    // Capture image rect on image click for transition
    cards.forEach((card) => {
      const imgLink = card.querySelector('.gd-card__img-link') as HTMLAnchorElement;
      if (imgLink) {
        imgLink.addEventListener('click', (e) => {
          e.preventDefault();
          const img = card.querySelector('.gd-card__img') as HTMLImageElement;
          if (img) {
            const rect = img.getBoundingClientRect();
            sessionStorage.setItem('ak-project-rect', JSON.stringify({
              top: rect.top, left: rect.left, width: rect.width, height: rect.height,
              slug: img.dataset.slug, coverImage: img.dataset.cover,
            }));
          }
          window.location.href = imgLink.href;
        });
      }

      // Card entrance animation
      if (prefersReducedMotion) {
        gsap.set(card, { opacity: 1, y: 0 });
      } else {
        gsap.fromTo(card,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
            scrollTrigger: { trigger: card, start: 'top 85%', once: true },
          }
        );
      }
    });

    // Header entrance
    const header = document.querySelector('.proj-page__header');
    if (header) {
      if (prefersReducedMotion) {
        gsap.set(header, { opacity: 1, y: 0 });
      } else {
        gsap.fromTo(header,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0, duration: 0.65, ease: 'power3.out', delay: 0.2 }
        );
      }
    }

    // Fluid CTA highlight — cursor pours into button
    if (!window.matchMedia('(hover: hover)').matches) return;
    document.querySelectorAll('.gd-card__ctas').forEach((container) => {
      const highlight = container.querySelector('.gd-cta-highlight') as HTMLElement;
      const ctas = container.querySelectorAll('.gd-cta');
      if (!highlight || !ctas.length) return;

      ctas.forEach((cta) => {
        cta.addEventListener('mouseenter', (e: Event) => {
          const me = e as MouseEvent;
          const el = cta as HTMLElement;
          const elRect = el.getBoundingClientRect();
          const cursorX = me.clientX - elRect.left + el.offsetLeft;
          const cursorY = me.clientY - elRect.top;

          highlight.style.left = el.offsetLeft + 'px';
          highlight.style.width = el.offsetWidth + 'px';
          highlight.style.clipPath = `circle(0% at ${cursorX - el.offsetLeft}px ${cursorY}px)`;
          highlight.style.opacity = '1';

          requestAnimationFrame(() => {
            highlight.style.transition = 'clip-path 0.45s cubic-bezier(0.4, 0, 0.2, 1), left 0.35s cubic-bezier(0.4, 0, 0.2, 1), width 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
            highlight.style.clipPath = `circle(150% at ${cursorX - el.offsetLeft}px ${cursorY}px)`;
          });

          ctas.forEach((c) => c.classList.remove('gd-cta--active'));
          el.classList.add('gd-cta--active');
        });
      });

      container.addEventListener('mouseleave', (e: Event) => {
        const me = e as MouseEvent;
        const containerRect = (container as HTMLElement).getBoundingClientRect();
        const cx = me.clientX - containerRect.left;
        const cy = me.clientY - containerRect.top;
        highlight.style.transition = 'clip-path 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.15s ease 0.2s';
        highlight.style.clipPath = `circle(0% at ${cx}px ${cy}px)`;
        setTimeout(() => { highlight.style.opacity = '0'; }, 300);
        ctas.forEach((c) => c.classList.remove('gd-cta--active'));
      });
    });
  }

  initProjectsPage();
  document.addEventListener('astro:after-swap', initProjectsPage);
</script>
