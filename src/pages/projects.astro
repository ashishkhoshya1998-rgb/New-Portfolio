---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav';
import FooterCTA from '../components/FooterCTA.astro';
import { projects } from '../data/projects';

// Sort projects by year descending (newest first)
const sorted = [...projects].sort((a, b) => Number(b.year) - Number(a.year));
---

<Layout title="Projects — Ashish Khoshya" description="Selected projects by Ashish Khoshya — design systems, enterprise UX, and product architecture.">
  <TopNav currentPath="/projects" client:load />

  <main id="main-content" class="proj-page">
    <!-- Header -->
    <div class="content-wrap proj-page__header">
      <h1 class="proj-page__header-title">Selected Projects</h1>
      <div class="proj-page__header-meta">
        <span class="proj-page__header-count">{sorted.length} Case Studies</span>
        <span class="proj-page__header-sep">/</span>
        <span class="proj-page__header-year">2021 — 2025</span>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="content-wrap proj-page__layout">
      <!-- Left — Sticky metadata panel -->
      <div class="proj-page__meta">
        <div class="proj-page__meta-inner">
          {sorted.map((p, i) => (
            <div
              class={`proj-page__meta-block ${i === 0 ? 'proj-page__meta-block--active' : ''}`}
              data-meta-index={i}
            >
              <span class="proj-page__meta-counter" style={`color: ${p.accentColor}`}>
                {String(i + 1).padStart(2, '0')}
              </span>
              <p class="proj-page__meta-title">{p.title}</p>
              <p class="proj-page__meta-desc">{p.overview}</p>
              <div class="proj-page__meta-details">
                <span class="proj-page__meta-label">Role</span>
                <span class="proj-page__meta-value">{p.role}</span>
              </div>
              <div class="proj-page__meta-details">
                <span class="proj-page__meta-label">Year</span>
                <span class="proj-page__meta-value">{p.year}</span>
              </div>
              <div class="proj-page__meta-details">
                <span class="proj-page__meta-label">Category</span>
                <span class="proj-page__meta-value">{p.category}</span>
              </div>
              <a href={`/project/${p.slug}`} class="proj-page__meta-cta" style={`color: ${p.accentColor}`}>
                Explore Project <span aria-hidden="true">→</span>
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Right — Project cards -->
      <div class="proj-page__cards">
        {sorted.map((p, i) => (
          <a
            href={`/project/${p.slug}`}
            class="proj-page__card"
            data-card-index={i}
            style={`border-color: ${p.accentColor}26; background: linear-gradient(135deg, var(--card-bg), ${p.accentColor}08);`}
          >
            <img
              src={p.coverImage}
              alt=""
              aria-hidden="true"
              class="proj-page__card-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
              data-slug={p.slug}
              data-cover={p.coverImage}
            />
            <div class="proj-page__card-gradient" />
            <div class="proj-page__card-inner">
              <h2 class="proj-page__card-title">{p.title}</h2>
              <span class="proj-page__card-meta">{p.category} · {p.year}</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div id="contact">
      <FooterCTA />
    </div>
  </main>
</Layout>

<style>
  .proj-page {
    padding-top: 120px;
  }

  /* Header */
  .proj-page__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 48px;
    padding-bottom: 20px;
    border-bottom: 0.5px solid var(--border);
  }

  .proj-page__header-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    color: var(--text);
    line-height: 1.1;
  }

  .proj-page__header-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  .proj-page__header-sep {
    opacity: 0.3;
  }

  .proj-page__header-count {
    font-weight: 500;
  }

  .proj-page__header-year {
    font-variant-numeric: tabular-nums;
  }

  /* Two-column layout */
  .proj-page__layout {
    display: grid;
    grid-template-columns: 40% 1fr;
    gap: 64px;
    align-items: start;
    padding-bottom: 96px;
  }

  /* Metadata panel */
  .proj-page__meta {
    position: sticky;
    top: 120px;
  }

  .proj-page__meta-inner {
    position: relative;
  }

  .proj-page__meta-block {
    display: none;
    flex-direction: column;
    gap: 16px;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
  }

  .proj-page__meta-block--active {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  .proj-page__meta-counter {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
  }

  .proj-page__meta-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
  }

  .proj-page__meta-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 380px;
  }

  .proj-page__meta-details {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .proj-page__meta-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    min-width: 80px;
  }

  .proj-page__meta-value {
    font-size: 14px;
    color: var(--text);
  }

  .proj-page__meta-cta {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    margin-top: 8px;
    transition: opacity 0.2s;
  }

  .proj-page__meta-cta:hover {
    opacity: 0.7;
  }

  /* Cards */
  .proj-page__cards {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .proj-page__card {
    position: relative;
    aspect-ratio: 16 / 9;
    border: 1px solid;
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    text-decoration: none;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .proj-page__card:hover {
    transform: scale(1.01);
    box-shadow: 0 12px 40px rgba(232,255,71,0.08);
  }

  .proj-page__card-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.5s var(--ease-out-expo);
    pointer-events: none;
  }

  .proj-page__card:hover .proj-page__card-cover {
    transform: scale(1.05);
  }

  .proj-page__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--gradient-overlay) 0%, var(--gradient-mid) 40%, var(--gradient-light) 70%, transparent 100%);
    pointer-events: none;
  }

  .proj-page__card-inner {
    position: relative;
    z-index: 1;
  }

  .proj-page__card-meta {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-top: 6px;
    display: block;
  }

  .proj-page__card-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    text-shadow: 0 2px 12px var(--shadow-color);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .proj-page {
      padding-top: 80px;
    }

    .proj-page__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 32px;
    }

    .proj-page__layout {
      display: flex;
      flex-direction: column;
      gap: 48px;
      padding-bottom: 64px;
    }

    .proj-page__meta {
      position: static;
      display: none;
    }

    .proj-page__cards {
      gap: 48px;
    }

    .proj-page__card {
      aspect-ratio: 3 / 2;
      padding: 20px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  gsap.ticker.lagSmoothing(0);
  if (document.hidden) {
    const interval = setInterval(() => gsap.ticker.tick(), 16);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) clearInterval(interval);
    }, { once: true });
  }

  function initProjectsPage() {
    // Capture image rect on card click for GSAP transition
    document.querySelectorAll('.proj-page__card').forEach((card) => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const img = card.querySelector('.proj-page__card-cover') as HTMLImageElement;
        if (img) {
          const rect = img.getBoundingClientRect();
          sessionStorage.setItem('ak-project-rect', JSON.stringify({
            top: rect.top, left: rect.left, width: rect.width, height: rect.height,
            slug: img.dataset.slug, coverImage: img.dataset.cover,
          }));
        }
        window.location.href = (card as HTMLAnchorElement).href;
      });
    });

    const cards = document.querySelectorAll('[data-card-index]');
    const metaBlocks = document.querySelectorAll('[data-meta-index]');

    if (!cards.length || !metaBlocks.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let activeIndex = 0;

    function setActiveMeta(index: number) {
      if (index === activeIndex && metaBlocks[activeIndex]?.classList.contains('proj-page__meta-block--active')) return;
      activeIndex = index;

      metaBlocks.forEach((block, i) => {
        if (i === index) {
          (block as HTMLElement).style.display = 'flex';
          requestAnimationFrame(() => {
            block.classList.add('proj-page__meta-block--active');
          });
        } else {
          block.classList.remove('proj-page__meta-block--active');
          setTimeout(() => {
            if (!block.classList.contains('proj-page__meta-block--active')) {
              (block as HTMLElement).style.display = 'none';
            }
          }, 400);
        }
      });
    }

    // ScrollTrigger for each card
    cards.forEach((card, i) => {
      ScrollTrigger.create({
        trigger: card,
        start: 'top 60%',
        end: 'bottom 40%',
        onEnter: () => setActiveMeta(i),
        onEnterBack: () => setActiveMeta(i),
      });

      // Entrance animation
      if (prefersReducedMotion) {
        gsap.set(card, { opacity: 1, y: 0 });
      } else {
        gsap.fromTo(card,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
            scrollTrigger: { trigger: card, start: 'top 80%', once: true },
          }
        );
      }
    });

    // Header entrance
    const header = document.querySelector('.proj-page__header');
    if (header) {
      if (prefersReducedMotion) {
        gsap.set(header, { opacity: 1, y: 0 });
      } else {
        gsap.fromTo(header,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0, duration: 0.65, ease: 'power3.out', delay: 0.2 }
        );
      }
    }

    // Meta panel entrance
    const meta = document.querySelector('.proj-page__meta');
    if (meta) {
      if (prefersReducedMotion) {
        gsap.set(meta, { opacity: 1, x: 0 });
      } else {
        gsap.fromTo(meta,
          { opacity: 0, x: -20 },
          {
            opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
            scrollTrigger: { trigger: meta, start: 'top 80%', once: true },
          }
        );
      }
    }
  }

  initProjectsPage();
  document.addEventListener('astro:after-swap', initProjectsPage);
</script>
