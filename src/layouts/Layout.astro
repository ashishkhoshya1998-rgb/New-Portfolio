---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ashish Khoshya — Senior Product Designer',
  description = 'Senior Product Designer with 5+ years delivering impactful digital experiences. Design systems, enterprise UX, and product architecture.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />

  </head>
  <body>
    <!-- Loading screen overlay -->
    <div id="ak-loader" aria-hidden="true">
      <div class="ak-loader__content">
        <div class="ak-loader__symbol">आ</div>
        <div class="ak-loader__name">ASHISH KHOSHYA</div>
      </div>
      <div class="ak-loader__bar"></div>
    </div>

    <!-- Skip to main content — keyboard accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot />

    <!-- Loading screen logic — vanilla JS, no framework -->
    <script is:inline>
      (function() {
        var loader = document.getElementById('ak-loader');
        if (!loader) return;

        if (sessionStorage.getItem('ak-loaded')) {
          loader.remove();
          return;
        }

        document.body.style.overflow = 'hidden';

        var bar = loader.querySelector('.ak-loader__bar');
        requestAnimationFrame(function() {
          if (bar) bar.style.width = '100%';
        });

        setTimeout(function() {
          loader.style.transform = 'translateY(-100%)';
          document.body.style.overflow = '';
          sessionStorage.setItem('ak-loaded', '1');

          setTimeout(function() {
            loader.remove();
          }, 800);
        }, 1800);
      })();

      // Remove loader from incoming pages during View Transitions
      document.addEventListener('astro:before-swap', function(e) {
        var incomingLoader = e.newDocument.getElementById('ak-loader');
        if (incomingLoader) incomingLoader.remove();
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ── Loading Screen ── */
  #ak-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.8s var(--ease-in-expo);
    will-change: transform;
  }

  .ak-loader__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .ak-loader__symbol {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 120px;
    line-height: 1;
    color: var(--accent);
  }

  .ak-loader__name {
    font-family: 'DM Sans', -apple-system, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Skip Link ── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 16px;
    z-index: 10000;
    padding: 12px 24px;
    background: var(--accent);
    color: var(--bg);
    font-size: 14px;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 16px;
  }

  /* ── Focus States ── */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .ak-loader__bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    transition: width 1.5s var(--ease-out-expo);
  }
</style>
