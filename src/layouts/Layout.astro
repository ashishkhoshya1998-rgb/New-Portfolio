---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Ashish Khoshya — Senior Product Designer',
  description = 'Senior Product Designer with 5+ years delivering impactful digital experiences. Design systems, enterprise UX, and product architecture.',
  ogImage = '/images/avatar.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <!-- Theme: prevent flash by setting before render -->
    <script is:inline>
      (function() {
        try {
          var saved = sessionStorage.getItem('ak-theme');
        } catch(e) { var saved = null; }
        var theme = 'dark';
        if (saved) {
          theme = saved;
        } else if (window.matchMedia) {
          theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="Ashish Khoshya" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LQ1G8E3DFD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      // ── Page categorisation ────────────────────────────────
      function akPageCategory(path) {
        if (path === '/' || path === '/index.html') return 'home';
        if (path.startsWith('/project/')) return 'project';
        if (path.startsWith('/projects')) return 'projects_list';
        if (path.startsWith('/deck/')) return 'presentation';
        if (path.startsWith('/about')) return 'about';
        if (path.startsWith('/resume')) return 'resume';
        return 'other';
      }
      function akPageSlug(path) {
        var m = path.match(/\/(project|deck)\/([^\/?#]+)/);
        return m ? m[2] : '';
      }

      // Initial config + first page_view with category
      gtag('config', 'G-LQ1G8E3DFD', {
        page_path: window.location.pathname,
        page_category: akPageCategory(window.location.pathname),
        page_slug: akPageSlug(window.location.pathname),
      });

      // ── Active time-on-page tracking ───────────────────────
      // Counts only visible, foregrounded seconds. Fires milestone
      // events at 15s, 30s, 60s, 120s, 300s, 600s and a final
      // engagement_end event on navigation / tab close.
      (function() {
        var MILESTONES = [15, 30, 60, 120, 300, 600];
        var state = null;

        function start(path) {
          state = {
            path: path,
            category: akPageCategory(path),
            slug: akPageSlug(path),
            activeMs: 0,
            lastTick: document.visibilityState === 'visible' ? Date.now() : 0,
            fired: {},
            interval: null,
          };
          state.interval = setInterval(tick, 1000);
        }

        function tick() {
          if (!state) return;
          if (document.visibilityState === 'visible' && state.lastTick) {
            var now = Date.now();
            state.activeMs += now - state.lastTick;
            state.lastTick = now;
          }
          var secs = Math.floor(state.activeMs / 1000);
          for (var i = 0; i < MILESTONES.length; i++) {
            var m = MILESTONES[i];
            if (secs >= m && !state.fired[m]) {
              state.fired[m] = true;
              gtag('event', 'time_on_page', {
                page_path: state.path,
                page_category: state.category,
                page_slug: state.slug,
                seconds: m,
                engagement_time_msec: m * 1000,
              });
            }
          }
        }

        function flush(reason) {
          if (!state) return;
          tick();
          var secs = Math.round(state.activeMs / 1000);
          if (secs > 0) {
            gtag('event', 'engagement_end', {
              page_path: state.path,
              page_category: state.category,
              page_slug: state.slug,
              seconds: secs,
              reason: reason || 'unload',
              engagement_time_msec: state.activeMs,
            });
          }
          if (state.interval) clearInterval(state.interval);
          state = null;
        }

        document.addEventListener('visibilitychange', function() {
          if (!state) return;
          if (document.visibilityState === 'hidden') {
            tick();
            state.lastTick = 0;
          } else {
            state.lastTick = Date.now();
          }
        });

        window.addEventListener('pagehide', function() { flush('pagehide'); }, { capture: true });

        // Astro view transitions
        document.addEventListener('astro:before-preparation', function() { flush('navigation'); });
        document.addEventListener('astro:after-swap', function() {
          var path = window.location.pathname;
          gtag('config', 'G-LQ1G8E3DFD', {
            page_path: path,
            page_category: akPageCategory(path),
            page_slug: akPageSlug(path),
          });
          start(path);
          // Re-apply theme after swap
          try { var saved = sessionStorage.getItem('ak-theme'); } catch(e) { var saved = null; }
          var theme = saved || (window.matchMedia ? (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark') : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        });

        // Kick off on initial load
        start(window.location.pathname);
      })();

      // ── Scroll depth tracking ──────────────────────────────
      // Fires scroll_depth events at 25/50/75/90/100% thresholds
      // and a final scroll_summary with the max depth reached
      // on navigation / tab close. Uses rAF-throttled scroll handler.
      (function() {
        var THRESHOLDS = [25, 50, 75, 90, 100];
        var state = null;
        var ticking = false;

        function start(path) {
          state = {
            path: path,
            category: akPageCategory(path),
            slug: akPageSlug(path),
            maxDepth: 0,
            fired: {},
          };
          // Capture initial depth (in case page loads pre-scrolled via anchor)
          measure();
        }

        function measure() {
          if (!state) return;
          var doc = document.documentElement;
          var body = document.body;
          var scrollTop = window.pageYOffset || doc.scrollTop || 0;
          var viewportH = window.innerHeight || doc.clientHeight || 0;
          var docH = Math.max(
            body.scrollHeight, doc.scrollHeight,
            body.offsetHeight, doc.offsetHeight,
            body.clientHeight, doc.clientHeight
          );
          var scrollable = Math.max(0, docH - viewportH);
          var pct = scrollable > 0 ? Math.min(100, Math.round(((scrollTop + viewportH) / docH) * 100)) : 100;
          if (pct > state.maxDepth) state.maxDepth = pct;

          for (var i = 0; i < THRESHOLDS.length; i++) {
            var t = THRESHOLDS[i];
            if (state.maxDepth >= t && !state.fired[t]) {
              state.fired[t] = true;
              gtag('event', 'scroll_depth', {
                page_path: state.path,
                page_category: state.category,
                page_slug: state.slug,
                percent: t,
              });
            }
          }
        }

        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function() {
            measure();
            ticking = false;
          });
        }

        function flush(reason) {
          if (!state) return;
          measure();
          gtag('event', 'scroll_summary', {
            page_path: state.path,
            page_category: state.category,
            page_slug: state.slug,
            max_depth: state.maxDepth,
            reason: reason || 'unload',
          });
          state = null;
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        window.addEventListener('pagehide', function() { flush('pagehide'); }, { capture: true });

        // Astro view transitions
        document.addEventListener('astro:before-preparation', function() { flush('navigation'); });
        document.addEventListener('astro:after-swap', function() {
          // Reset state for new page; small delay to let new content render
          setTimeout(function() { start(window.location.pathname); }, 50);
        });

        // Kick off on initial load
        start(window.location.pathname);
      })();

      // ── Live OS theme detection ──────────────────────────
      // When the OS theme changes, always follow it and clear any manual override
      (function() {
        if (!window.matchMedia) return;
        var mq = window.matchMedia('(prefers-color-scheme: light)');
        function onThemeChange(e) {
          var newTheme = e.matches ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', newTheme);
          try { sessionStorage.removeItem('ak-theme'); } catch(err) {}
        }
        if (mq.addEventListener) {
          mq.addEventListener('change', onThemeChange);
        } else if (mq.addListener) {
          mq.addListener(onThemeChange);
        }
      })();

      // ── Click / download tracking ──────────────────────────
      document.addEventListener('click', function(e) {
        var a = e.target && e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        // PDF downloads (resume)
        if (/\.pdf($|\?)/i.test(href)) {
          var file = href.split('/').pop().split('?')[0];
          var variant = /ats/i.test(file) ? 'ats' : (/designed/i.test(file) ? 'designed' : 'other');
          gtag('event', 'file_download', {
            file_name: file,
            file_extension: 'pdf',
            link_url: href,
            resume_variant: variant,
          });
        }
        // Resume page view (from CTA)
        if (href === '/resume.html' || href.indexOf('/resume') === 0) {
          gtag('event', 'resume_click', {
            link_url: href,
            source_path: window.location.pathname,
          });
        }
        // Presentation deck click
        if (href.indexOf('/deck/') === 0) {
          gtag('event', 'presentation_click', {
            deck_slug: href.replace('/deck/', '').replace(/\/$/, ''),
            source_path: window.location.pathname,
          });
        }
        // Project card click
        if (href.indexOf('/project/') === 0) {
          gtag('event', 'project_click', {
            project_slug: href.replace('/project/', '').replace(/\/$/, ''),
            source_path: window.location.pathname,
          });
        }
      }, true);
    </script>

  </head>
  <body>
    <!-- Loading screen overlay -->
    <div id="ak-loader" aria-hidden="true">
      <div class="ak-loader__content">
        <div class="ak-loader__symbol" lang="hi" aria-hidden="true">आ</div>
        <div class="ak-loader__name">ASHISH KHOSHYA</div>
      </div>
      <div class="ak-loader__bar"></div>
    </div>

    <!-- Skip to main content — keyboard accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot />

    <!-- Custom cursor (Google Design style) -->
    <div id="ak-cursor" class="ak-cursor" aria-hidden="true">
      <span class="ak-cursor__text"></span>
    </div>

    <!-- Loading screen logic — vanilla JS, no framework -->
    <script is:inline>
      (function() {
        var loader = document.getElementById('ak-loader');
        if (!loader) return;

        if (sessionStorage.getItem('ak-loaded')) {
          loader.remove();
          return;
        }

        document.body.style.overflow = 'hidden';

        var bar = loader.querySelector('.ak-loader__bar');
        requestAnimationFrame(function() {
          if (bar) bar.style.width = '100%';
        });

        setTimeout(function() {
          loader.style.transform = 'translateY(-100%)';
          document.body.style.overflow = '';
          sessionStorage.setItem('ak-loaded', '1');

          setTimeout(function() {
            loader.remove();
          }, 800);
        }, 1800);
      })();

      // Remove loader from incoming pages during View Transitions
      document.addEventListener('astro:before-swap', function(e) {
        var incomingLoader = e.newDocument.getElementById('ak-loader');
        if (incomingLoader) incomingLoader.remove();
      });
    </script>

    <!-- Custom cursor logic -->
    <script is:inline>
    (function() {
      // Prevent duplicate initialization across view transitions
      if (window.__akCursorInit) return;
      window.__akCursorInit = true;

      if ('ontouchstart' in window || navigator.maxTouchPoints > 0) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var cursor, textEl;
      var mx = -100, my = -100, cx = -100, cy = -100;
      var state = 'default';
      var currentLabel = '';
      var visible = false;
      var rafId = null;

      var SCALE_DEFAULT = 0.28;
      var SCALE_EXPAND = 1;
      var SCALE_ABSORBED = 0;
      var currentScale = SCALE_DEFAULT;

      function grab() {
        cursor = document.getElementById('ak-cursor');
        textEl = cursor ? cursor.querySelector('.ak-cursor__text') : null;
      }

      function lerp(a, b, n) { return a + (b - a) * n; }

      function render() {
        if (!cursor) { rafId = requestAnimationFrame(render); return; }
        cx = lerp(cx, mx, 0.45);
        cy = lerp(cy, my, 0.45);
        var targetScale = state === 'hidden' ? SCALE_ABSORBED :
                          state === 'expand' ? SCALE_EXPAND : SCALE_DEFAULT;
        // Faster lerp for absorb/release to feel snappy
        var scaleLerp = state === 'hidden' ? 0.25 : (currentScale < 0.05 ? 0.3 : 0.18);
        currentScale = lerp(currentScale, targetScale, scaleLerp);
        // Clamp tiny values to 0
        if (currentScale < 0.005) currentScale = 0;
        cursor.style.transform = 'translate(' + cx + 'px,' + cy + 'px) translate(-50%,-50%) scale(' + currentScale + ')';
        rafId = requestAnimationFrame(render);
      }

      function getState(el) {
        if (!el) return 'default';
        var node = el;
        for (var i = 0; i < 8; i++) {
          if (!node || !node.getAttribute) break;
          if (node.getAttribute && node.getAttribute('data-cursor') === 'expand') return 'expand';
          var tag = node.tagName;
          if (tag === 'A' || tag === 'BUTTON') return 'hidden';
          node = node.parentElement;
        }
        return 'default';
      }

      function getLabel(el) {
        if (!el) return '';
        var node = el;
        for (var i = 0; i < 8; i++) {
          if (!node || !node.getAttribute) break;
          var lbl = node.getAttribute('data-cursor');
          if (lbl) return lbl;
          node = node.parentElement;
        }
        return '';
      }

      document.addEventListener('mousemove', function(e) {
        mx = e.clientX;
        my = e.clientY;

        if (!cursor) grab();
        if (!cursor) return;

        if (!visible) {
          visible = true;
          cursor.classList.add('ak-cursor--visible');
          if (!rafId) render();
        }

        var target = document.elementFromPoint(e.clientX, e.clientY);
        var newState = getState(target);
        var label = getLabel(target);

        if (newState !== state) {
          state = newState;
          cursor.classList.toggle('ak-cursor--hidden', state === 'hidden');
          cursor.classList.toggle('ak-cursor--label', state === 'expand' && !!label);
        }
        if (label !== currentLabel) {
          currentLabel = label;
          if (textEl) textEl.textContent = label;
          cursor.classList.toggle('ak-cursor--label', state === 'expand' && !!label);
        }
      });

      document.addEventListener('mouseleave', function() {
        visible = false;
        if (cursor) cursor.classList.remove('ak-cursor--visible');
      });

      document.addEventListener('mousedown', function() {
        if (cursor) cursor.classList.add('ak-cursor--press');
      });
      document.addEventListener('mouseup', function() {
        if (cursor) cursor.classList.remove('ak-cursor--press');
      });

      // After view transition: re-grab DOM, reset visibility so next mousemove re-shows
      document.addEventListener('astro:after-swap', function() {
        grab();
        visible = false;
        state = 'default';
        currentLabel = '';
        // Immediately show if mouse is already on the page
        if (cursor && mx > 0 && my > 0) {
          cx = mx; cy = mx;
          visible = true;
          cursor.classList.add('ak-cursor--visible');
        }
      });

      grab();
      render();
    })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ── Loading Screen ── */
  #ak-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.8s var(--ease-in-expo);
    will-change: transform;
  }

  .ak-loader__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .ak-loader__symbol {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 120px;
    line-height: 1;
    color: var(--accent);
  }

  .ak-loader__name {
    font-family: 'DM Sans', -apple-system, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Skip Link ── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 16px;
    z-index: 10000;
    padding: 12px 24px;
    background: var(--accent);
    color: var(--bg);
    font-size: 14px;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 16px;
  }

  /* ── Focus States ── */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .ak-loader__bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    transition: width 1.5s var(--ease-out-expo);
  }

  /* ── Global: themed hover highlight for all interactive elements ── */
  /* Excludes elements with their own fluid highlight systems */
  a:not(.topnav__link):not(.topnav__cta):not(.topnav__brand):not(.topnav__socials-dropdown-link):not(.gd-cta):not(.mobile-menu__link):not(.mobile-menu__cta):not(.mobile-menu__social):not(.skip-link):not(.footer__email),
  button:not(.topnav__theme-toggle):not(.topnav__socials-btn):not(.topnav__hamburger):not(.mobile-menu__close) {
    cursor: none;
  }
</style>
