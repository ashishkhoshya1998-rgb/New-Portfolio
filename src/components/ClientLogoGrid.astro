---
const clients = ['Visit Health', 'ClearTax', 'Zzazz.ai'];
---

<section class="logo-section">
  <div class="content-wrap">
    <p class="logo-section__label">Industry leaders I worked for</p>
    <div class="logo-section__row" data-logo-row>
      {clients.map((name, i) => (
        <>
          <span class="logo-section__name">{name}</span>
          {i < clients.length - 1 && <span class="logo-section__dot" aria-hidden="true">·</span>}
        </>
      ))}
      <a href="mailto:ashish.khoshya1998@gmail.com" class="logo-section__cta">Your company →</a>
    </div>
  </div>
</section>

<style>
  .logo-section {
    padding: 64px 0;
  }

  .logo-section__label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .logo-section__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 24px;
  }

  .logo-section__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.3px;
  }

  .logo-section__dot {
    font-size: 24px;
    color: var(--text-muted);
    opacity: 0.4;
    user-select: none;
  }

  .logo-section__cta {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-left: 8px;
    transition: opacity 0.2s;
  }

  .logo-section__cta:hover {
    opacity: 0.7;
  }

  @media (max-width: 1024px) {
    .logo-section {
      padding: 40px 0;
    }
  }

  @media (max-width: 768px) {
    .logo-section {
      padding: 32px 0;
    }

    .logo-section__name {
      font-size: 18px;
    }

    .logo-section__row {
      gap: 8px 16px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  gsap.ticker.lagSmoothing(0);
  if (document.hidden) {
    const interval = setInterval(() => gsap.ticker.tick(), 16);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) clearInterval(interval);
    }, { once: true });
  }

  function initLogoRow() {
    const row = document.querySelector('[data-logo-row]');
    if (!row) return;

    gsap.fromTo(row,
      { opacity: 0, y: 16 },
      {
        opacity: 1, y: 0, duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: row, start: 'top 80%', once: true },
      }
    );
  }

  initLogoRow();
  document.addEventListener('astro:after-swap', initLogoRow);
</script>
