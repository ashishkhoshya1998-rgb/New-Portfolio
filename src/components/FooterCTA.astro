<footer class="footer">
  <!-- 1. Philosophy -->
  <div class="content-wrap footer__philosophy" data-footer-section>
    <span class="footer__eyebrow">Got a challenge worth solving?</span>
    <h2 class="footer__heading">Let's make something happen together</h2>
    <p class="footer__text">
      As a designer from IIT Guwahati, I believe design is about serving user needs — finding
      the right balance between user psychology and business goals.
    </p>
  </div>

  <!-- 2. Links -->
  <div class="content-wrap footer__links" data-footer-section>
    <div class="footer__links-grid">
      <div class="footer__links-col">
        <span class="footer__links-label">Socials</span>
        <a href="https://www.linkedin.com/in/ashish-khoshya-676b99183/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (opens in new tab)">LinkedIn</a>
        <a href="https://www.behance.net/ashishkhos9d01" target="_blank" rel="noopener noreferrer" aria-label="Behance (opens in new tab)">Behance</a>
        <a href="https://github.com/ashishkhoshya1998-rgb" target="_blank" rel="noopener noreferrer" aria-label="GitHub (opens in new tab)">GitHub</a>
      </div>
      <div class="footer__links-col">
        <span class="footer__links-label">Contact</span>
        <a href="mailto:ashish.khoshya1998@gmail.com" class="footer__email">ashish.khoshya1998@gmail.com</a>
      </div>
    </div>
    <p class="footer__copyright">© 2026 Ashish Khoshya</p>
  </div>
</footer>

<style>
  .footer {
    padding: 96px 0 48px;
    border-top: 1px solid var(--border);
  }

  /* 1. Philosophy */
  .footer__philosophy {
    margin-bottom: 80px;
  }

  .footer__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .footer__heading {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 20px;
    max-width: 700px;
  }

  .footer__text {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
  }

  /* 2. Links */
  .footer__links {
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .footer__links-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 500px;
    margin-bottom: 48px;
  }

  .footer__links-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__links-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--accent);
    margin-bottom: 4px;
  }

  .footer__links-col a {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    padding: 6px 0;
    display: inline-flex;
    align-items: center;
    min-height: 32px;
  }

  .footer__email {
    font-family: var(--font-display);
    font-size: 18px !important;
    color: var(--accent) !important;
    letter-spacing: 0.2px;
  }

  .footer__email:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 768px) {
    .footer__links-col a {
      min-height: 44px;
      padding: 10px 0;
    }
  }

  .footer__links-col a:hover {
    color: var(--accent);
  }

  .footer__copyright {
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .footer {
      padding: 64px 0 32px;
    }

    .footer__philosophy {
      margin-bottom: 48px;
    }

    .footer__heading {
      font-size: 28px;
    }

    .footer__email {
      font-size: 15px !important;
      word-break: break-all;
    }

    .footer__links-grid {
      gap: 32px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  gsap.ticker.lagSmoothing(0);
  if (document.hidden) {
    const interval = setInterval(() => gsap.ticker.tick(), 16);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) clearInterval(interval);
    }, { once: true });
  }

  function initFooter() {
    const sections = document.querySelectorAll('[data-footer-section]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      gsap.set(sections, { opacity: 1, y: 0 });
      return;
    }
    sections.forEach((section) => {
      gsap.fromTo(section,
        { opacity: 0, y: 30 },
        {
          opacity: 1, y: 0, duration: 0.65, ease: 'power3.out',
          scrollTrigger: { trigger: section, start: 'top 80%', once: true },
        }
      );
    });
  }

  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>
