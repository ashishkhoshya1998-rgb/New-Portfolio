---
/**
 * Visualises the same component (an Action Dropdown) shipped in 4 different
 * styles by 4 different product teams — the cross-team duplication problem
 * the case study describes.
 */
interface Props {
  /** Team names for the 4 columns. */
  teams?: [string, string, string, string];
  /** Caption shown below the grid. */
  caption?: string;
}

const {
  teams = ["Platform", "GST", "Supply Chain", "E-Invoicing"],
  caption,
} = Astro.props;
---

<figure class="dup-components" data-cs-section>
  <figcaption class="dup-components__title">Same component, four teams</figcaption>
  <div class="dup-components__grid">
    {/* ── v1 — Platform: sharp corners, plain items, no icons ── */}
    <div class="dup-components__col">
      <span class="dup-components__team">{teams[0]}</span>
      <div class="dup-mock dup-mock--v1">
        <div class="dup-mock__trigger dup-mock__trigger--block">
          Actions <span aria-hidden="true">▾</span>
        </div>
        <div class="dup-mock__menu">
          <div class="dup-mock__item">Edit</div>
          <div class="dup-mock__item">Duplicate</div>
          <div class="dup-mock__item">Delete</div>
        </div>
      </div>
    </div>

    {/* ── v2 — GST: kebab trigger, bullet icons, divider ── */}
    <div class="dup-components__col">
      <span class="dup-components__team">{teams[1]}</span>
      <div class="dup-mock dup-mock--v2">
        <div class="dup-mock__trigger dup-mock__trigger--kebab" aria-hidden="true">⋮</div>
        <div class="dup-mock__menu">
          <div class="dup-mock__item"><span class="dup-mock__bullet"></span>Edit</div>
          <div class="dup-mock__item"><span class="dup-mock__bullet"></span>Duplicate</div>
          <div class="dup-mock__divider"></div>
          <div class="dup-mock__item dup-mock__item--danger"><span class="dup-mock__bullet"></span>Delete</div>
        </div>
      </div>
    </div>

    {/* ── v3 — Supply Chain: pill trigger, soft rounded menu, bigger padding ── */}
    <div class="dup-components__col">
      <span class="dup-components__team">{teams[2]}</span>
      <div class="dup-mock dup-mock--v3">
        <div class="dup-mock__trigger dup-mock__trigger--pill">
          Actions <span aria-hidden="true">▼</span>
        </div>
        <div class="dup-mock__menu">
          <div class="dup-mock__item">Edit row</div>
          <div class="dup-mock__item">Duplicate row</div>
          <div class="dup-mock__item">Archive</div>
          <div class="dup-mock__item">Delete</div>
        </div>
      </div>
    </div>

    {/* ── v4 — E-Invoicing: text-link trigger, items with shortcut hints ── */}
    <div class="dup-components__col">
      <span class="dup-components__team">{teams[3]}</span>
      <div class="dup-mock dup-mock--v4">
        <div class="dup-mock__trigger dup-mock__trigger--link">
          More options <span aria-hidden="true">↓</span>
        </div>
        <div class="dup-mock__menu">
          <div class="dup-mock__item dup-mock__item--shortcut">
            <span>Edit</span><span class="dup-mock__kbd">⌘E</span>
          </div>
          <div class="dup-mock__item dup-mock__item--shortcut">
            <span>Duplicate</span><span class="dup-mock__kbd">⌘D</span>
          </div>
          <div class="dup-mock__item dup-mock__item--shortcut">
            <span>Delete</span><span class="dup-mock__kbd">⌘⌫</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  {caption && <p class="dup-components__caption">{caption}</p>}
</figure>

<style>
  .dup-components {
    margin: 48px 0;
    padding: 28px 24px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .dup-components__title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 22px;
    text-align: center;
  }
  .dup-components__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    align-items: start;
  }
  .dup-components__col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }
  .dup-components__team {
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: left;
  }

  /* ── Mock primitives ───────────────────────────────────────── */
  .dup-mock {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .dup-mock__trigger {
    font-family: var(--font-body);
    font-size: 11.5px;
    font-weight: 500;
    color: var(--text);
    background: color-mix(in srgb, var(--text) 4%, transparent);
    border: 1px solid var(--border);
    padding: 6px 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    line-height: 1;
  }
  .dup-mock__menu {
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--text) 5%, var(--card-bg));
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .dup-mock__item {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--text-subtle);
    padding: 6px 10px;
    display: flex;
    align-items: center;
    gap: 6px;
    line-height: 1.3;
  }
  .dup-mock__item--danger {
    color: #f4b562;
  }
  .dup-mock__item--shortcut {
    justify-content: space-between;
  }
  .dup-mock__bullet {
    width: 4px;
    height: 4px;
    background: currentColor;
    border-radius: 50%;
    opacity: 0.55;
  }
  .dup-mock__divider {
    height: 1px;
    background: var(--border);
    margin: 2px 6px;
  }
  .dup-mock__kbd {
    font-family: ui-monospace, "SF Mono", "Menlo", monospace;
    font-size: 9.5px;
    color: var(--text-muted);
    padding: 1px 4px;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: color-mix(in srgb, var(--text) 3%, transparent);
  }

  /* ── v1 — Platform: sharp, minimal ────────────────────────── */
  .dup-mock--v1 .dup-mock__trigger { border-radius: 0; }
  .dup-mock--v1 .dup-mock__menu { border-radius: 0; }

  /* ── v2 — GST: kebab + slight rounding + dividers ─────────── */
  .dup-mock--v2 .dup-mock__trigger {
    border-radius: 4px;
    padding: 3px 8px;
    font-size: 14px;
    font-weight: 700;
    line-height: 1;
  }
  .dup-mock--v2 .dup-mock__menu { border-radius: 4px; }

  /* ── v3 — Supply Chain: pill, soft rounding, bigger padding ─ */
  .dup-mock--v3 .dup-mock__trigger {
    border-radius: 999px;
    padding: 6px 12px;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
    color: var(--accent);
  }
  .dup-mock--v3 .dup-mock__menu {
    border-radius: 8px;
  }
  .dup-mock--v3 .dup-mock__item {
    padding: 7px 12px;
  }

  /* ── v4 — E-Invoicing: text-link trigger, shortcuts in menu ─ */
  .dup-mock--v4 .dup-mock__trigger {
    background: transparent;
    border: 0;
    color: var(--accent);
    padding: 0 0 2px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
    border-radius: 0;
  }
  .dup-mock--v4 .dup-mock__menu { border-radius: 0; }

  /* ── Caption ───────────────────────────────────────────────── */
  .dup-components__caption {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 22px 0 0;
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .dup-components {
      padding: 20px 16px;
    }
    .dup-components__grid {
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
  }
  @media (max-width: 480px) {
    .dup-components__grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
</style>
