---
interface Props {
  number: string;
  title: string;
}

const { number, title } = Astro.props;
---

<div class="process-step" data-cs-section>
  <span class="process-step__number">{number}</span>
  <div class="process-step__body">
    <h3 class="process-step__title">{title}</h3>
    <div class="process-step__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .process-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }

  .process-step:first-of-type {
    border-top: 1px solid var(--border);
  }

  .process-step__number {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 1px;
    opacity: 0.5;
    padding-top: 4px;
    flex-shrink: 0;
    width: 24px;
  }

  .process-step__body {
    flex: 1;
  }

  .process-step__title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .process-step__content {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .process-step__content :global(p) {
    margin: 0;
  }

  @media (max-width: 768px) {
    .process-step {
      gap: 12px;
      padding: 16px 0;
    }
  }
</style>
