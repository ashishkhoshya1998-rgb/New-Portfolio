---
interface Stage {
  /** Stage name, e.g. "Completed Data Source step" */
  label: string;
  /** Percentage 0–100 used both for the displayed value and bar width */
  value: number;
  /** Optional short note shown under the row, e.g. "the drop" */
  note?: string;
  /** "alert" tints the row to flag a counter-signal (e.g. Excel reversion) */
  variant?: "default" | "alert";
}
interface Props {
  stages: Stage[];
  caption?: string;
}

const { stages, caption } = Astro.props;
---

<div class="funnel-chart" data-cs-section>
  <ol class="funnel-chart__list">
    {stages.map((s) => (
      <li class:list={[
        "funnel-chart__row",
        s.variant === "alert" && "funnel-chart__row--alert",
      ]}>
        <div class="funnel-chart__head">
          <span class="funnel-chart__value">{s.value}%</span>
          <span class="funnel-chart__label">{s.label}</span>
        </div>
        <div class="funnel-chart__track">
          <div
            class="funnel-chart__bar"
            style={`width: ${Math.min(100, Math.max(0, s.value))}%`}
          ></div>
        </div>
        {s.note && <span class="funnel-chart__note">{s.note}</span>}
      </li>
    ))}
  </ol>
  {caption && <p class="funnel-chart__caption">{caption}</p>}
</div>

<style>
  .funnel-chart {
    margin: 48px 0;
  }
  .funnel-chart .funnel-chart__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .funnel-chart__row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .funnel-chart__head {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .funnel-chart__value {
    font-family: var(--font-body);
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--accent);
    font-feature-settings: "tnum" 1;
    min-width: 4ch;
  }
  .funnel-chart__label {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-subtle);
    letter-spacing: 0.005em;
  }
  .funnel-chart__track {
    position: relative;
    height: 10px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    overflow: hidden;
  }
  .funnel-chart__bar {
    position: absolute;
    inset: 0 auto 0 0;
    background: linear-gradient(
      90deg,
      var(--accent),
      color-mix(in srgb, var(--accent) 55%, transparent)
    );
    border-radius: inherit;
    transition: width 0.6s ease;
  }
  .funnel-chart__note {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    padding-left: 4ch;
    margin-top: 2px;
  }

  /* Alert variant — for counter-signals (e.g. Excel reversion) */
  .funnel-chart__row--alert .funnel-chart__value {
    color: #f4b562;
  }
  .funnel-chart__row--alert .funnel-chart__bar {
    background: linear-gradient(
      90deg,
      #f4b562,
      color-mix(in srgb, #f4b562 55%, transparent)
    );
  }

  .funnel-chart__caption {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 24px 0 0;
    text-align: center;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .funnel-chart {
      margin: 32px 0;
    }
    .funnel-chart .funnel-chart__list {
      gap: 18px;
    }
    .funnel-chart__head {
      gap: 12px;
    }
    .funnel-chart__value {
      font-size: 24px;
    }
    .funnel-chart__label {
      font-size: 13px;
    }
    .funnel-chart__note {
      padding-left: 0;
    }
  }
</style>
