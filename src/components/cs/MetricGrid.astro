---
interface Props {
  metrics: { value: string; label: string }[];
}

const { metrics } = Astro.props;
---

<div class="metric-grid" data-cs-section>
  {metrics.map((m) => (
    <div class="metric-grid__item">
      <span class="metric-grid__value">{m.value}</span>
      <span class="metric-grid__label">{m.label}</span>
    </div>
  ))}
</div>

<style>
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    padding: 40px 0;
    margin: 48px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .metric-grid__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .metric-grid__value {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--accent);
  }

  .metric-grid__label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .metric-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      padding: 32px 0;
      margin: 32px 0;
    }

    .metric-grid__value {
      font-size: 28px;
    }
  }
</style>
