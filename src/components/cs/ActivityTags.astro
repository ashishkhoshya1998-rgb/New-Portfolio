---
interface Props {
  items: string[];
  label?: string;
}

const { items, label = "Activities and outputs" } = Astro.props;
---

<div class="activity-tags">
  <span class="activity-label">{label}</span>
  <ul class="activity-list">
    {items.map((item) => <li class="activity-chip">{item}</li>)}
  </ul>
</div>

<style>
  .activity-tags {
    margin: 2rem 0 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .activity-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
  }
  .activity-tags .activity-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .activity-chip {
    font-size: 0.6875rem;
    line-height: 1;
    padding: 0.375rem 0.625rem;
    border-radius: 999px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--text);
    white-space: nowrap;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  @media (max-width: 640px) {
    .activity-tags {
      margin: 1.5rem 0 2rem;
      padding-top: 0.875rem;
    }
    .activity-label {
      font-size: 0.625rem;
    }
    .activity-chip {
      font-size: 0.625rem;
      padding: 0.3125rem 0.5625rem;
    }
  }
</style>
