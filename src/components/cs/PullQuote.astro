---
interface Props {
  attribution?: string;
}

const { attribution } = Astro.props;
---

<figure class="pull-quote">
  <div class="pull-quote__mark" aria-hidden="true">"</div>
  <blockquote class="pull-quote__quote">
    <slot />
  </blockquote>
  {attribution && (
    <figcaption class="pull-quote__attribution">— {attribution}</figcaption>
  )}
</figure>

<style>
  .pull-quote {
    position: relative;
    margin: 32px 0;
    padding: 0 0 0 24px;
    border-left: 2px solid var(--accent);
  }

  .pull-quote__mark {
    position: absolute;
    top: -10px;
    left: 12px;
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    opacity: 0.5;
    pointer-events: none;
  }

  /* Override the case study page's global blockquote styling */
  figure.pull-quote blockquote.pull-quote__quote {
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    font-style: italic;
    color: var(--text);
    line-height: 1.4;
    letter-spacing: -0.3px;
  }

  figure.pull-quote blockquote.pull-quote__quote :global(p) {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    line-height: inherit;
    font-style: inherit;
    margin: 0;
  }

  .pull-quote__attribution {
    margin-top: 12px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    font-style: normal;
    letter-spacing: 0.2px;
  }

  @media (max-width: 640px) {
    .pull-quote {
      margin: 24px 0;
      padding: 0 0 0 18px;
    }
    .pull-quote__quote {
      font-size: 18px;
    }
    .pull-quote__mark {
      font-size: 36px;
      top: -6px;
      left: 8px;
    }
  }
</style>
