---
interface Props {
  attribution: string;
  context?: string;
}

const { attribution, context } = Astro.props;
---

<aside class="testimonial">
  <div class="testimonial__mark" aria-hidden="true">"</div>
  <blockquote class="testimonial__quote">
    <slot />
  </blockquote>
  <footer class="testimonial__attribution">
    <span class="testimonial__name">{attribution}</span>
    {context && <span class="testimonial__context"> · {context}</span>}
  </footer>
</aside>

<style>
  .testimonial {
    position: relative;
    margin: 64px 0 32px;
    padding: 48px 32px 36px;
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
    border-radius: 20px;
    text-align: center;
  }

  .testimonial__mark {
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 0.4;
    color: var(--accent);
    opacity: 0.55;
    margin-bottom: 18px;
  }

  /* Override the case study page's global blockquote styling */
  aside.testimonial blockquote.testimonial__quote {
    margin: 0 auto 20px;
    max-width: 620px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: 500;
    color: var(--text);
    line-height: 1.5;
    letter-spacing: -0.3px;
    text-align: center;
  }

  aside.testimonial blockquote.testimonial__quote :global(p) {
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    line-height: inherit;
    margin: 0;
    font-style: inherit;
  }

  .testimonial__attribution {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.2px;
  }

  .testimonial__name {
    font-weight: 600;
    color: var(--text);
  }

  @media (max-width: 640px) {
    .testimonial {
      padding: 36px 22px 28px;
      margin: 48px 0 24px;
      border-radius: 16px;
    }
    .testimonial__quote {
      font-size: 18px;
    }
    .testimonial__mark {
      font-size: 48px;
      margin-bottom: 12px;
    }
  }
</style>
